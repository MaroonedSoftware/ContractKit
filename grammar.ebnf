(* ===================================================================== *)
(* Contract DSL Grammar                                                  *)
(* Extended Backus-Naur Form (ISO/IEC 14977)                             *)
(*                                                                       *)
(* Two sublanguages:                                                     *)
(*   .dto  — Data Transfer Object schemas  (compiles to Zod)            *)
(*   .op   — RESTful API operations        (compiles to Koa routers)    *)
(*                                                                       *)
(* Brace-delimited blocks. Newlines and whitespace are not significant   *)
(* outside of string literals.                                           *)
(* ===================================================================== *)


(* --------------------------------------------------------------------- *)
(* Terminals                                                             *)
(* --------------------------------------------------------------------- *)

IDENTIFIER  = letter , { letter | digit | "-" | "." | "_" | "$" } ;
STRING_LIT  = ( '"' , { ? any character except '"' ? } , '"' )
            | ( "'" , { ? any character except "'" ? } , "'" ) ;
NUMBER_LIT  = [ "-" ] , digit , { digit } , [ "." , digit , { digit } ] ;
BOOLEAN_LIT = "true" | "false" ;
TRIPLE_DASH = "---" ;
COMMENT     = "#" , { ? any character except newline ? } ;
                  (* On a field line → .describe("comment")              *)
                  (* On a model line → JSDoc block above export const    *)

letter      = "a" | "b" | ... | "z" | "A" | "B" | ... | "Z" | "_" | "$" ;
digit       = "0" | "1" | ... | "9" ;

EOF         = ? end of file ? ;


(* --------------------------------------------------------------------- *)
(* Front-matter (shared by .dto and .op files)                           *)
(* --------------------------------------------------------------------- *)

frontMatter     = TRIPLE_DASH , { metaEntry } , TRIPLE_DASH ;
                  (* key-value metadata block                              *)
                  (* In .dto: template variables for output paths          *)
                  (* In .op:  explicit service import paths                *)

metaEntry       = IDENTIFIER , ":" , ( STRING_LIT | IDENTIFIER ) ;
                  (* key: value — value may be quoted or unquoted          *)
                  (* Inside front-matter, # is NOT treated as a comment    *)
                  (* so unquoted paths like #modules/foo.js are valid      *)


(* ===================================================================== *)
(* Part 1 — DTO Grammar  (.dto files)                                   *)
(* ===================================================================== *)

dtoRoot         = [ frontMatter ] , { modelDecl } , EOF ;

(* --------------------------------------------------------------------- *)
(* Models                                                                *)
(* --------------------------------------------------------------------- *)

modelDecl       = IDENTIFIER , ":" ,
                  ( IDENTIFIER , "{" , fieldList , "}"   (* inheritance   *)
                  | "{" , fieldList , "}"                 (* plain model   *)
                  | typeExpression ) ;                    (* type alias    *)
                  (* first IDENTIFIER  = model name                      *)
                  (* second IDENTIFIER = base model for inheritance      *)
                  (* type alias form: Name : string | number             *)

(* --------------------------------------------------------------------- *)
(* Fields                                                                *)
(* --------------------------------------------------------------------- *)

fieldList       = { fieldDecl } ;

fieldDecl       = IDENTIFIER , [ "?" ] , ":" , fieldBody ;
                  (* IDENTIFIER = field name                             *)
                  (* "?" marks the field as optional                     *)

fieldBody       = visibilityField                       (* case 1 *)
                | typeField ;                           (* case 2 *)
                  (* nested objects are handled via typeExpression       *)
                  (* → intersectionExpr → singleType → inlineBraceObject *)

(* Case 1 — visibility modifier + type *)
visibilityField = visibility , typeExpression ,
                  [ "=" , defaultValue ] ;

visibility      = "readonly" | "writeonly" ;
                  (* readonly  = response/read schema only               *)
                  (* writeonly = request/write schema only                *)
                  (* Placed after ":", before the type expression         *)

(* Case 2 — plain type expression *)
typeField       = typeExpression ,
                  [ "=" , defaultValue ] ;

(* --------------------------------------------------------------------- *)
(* Type Expressions                                                      *)
(* --------------------------------------------------------------------- *)

typeExpression  = intersectionExpr , { "|" , intersectionExpr } ;
                  (* pipe-separated union: string | number               *)
                  (* trailing | null → .nullable() not z.union           *)

intersectionExpr = singleType , { "&" , singleType } ;
                  (* ampersand-separated intersection                    *)
                  (* higher precedence than union                        *)
                  (* e.g. Pagination & { sortBy?: string }               *)

singleType      = inlineBraceObject
                | IDENTIFIER , [ "(" , typeArgs , ")" ] ;
                  (* IDENTIFIER = type name (scalar, compound, or ref)   *)
                  (* optional parenthesized arguments for constraints    *)

                  (* Known scalar types:                                 *)
                  (*   string, number, int, bigint, boolean,             *)
                  (*   date, datetime, email, url, uuid,                 *)
                  (*   any, unknown, null, object, binary                *)
                  (*                                                     *)
                  (* Known compound types (with args):                   *)
                  (*   array(type [, min=N, max=N])                      *)
                  (*   tuple(type, type, ...)                            *)
                  (*   record(keyType, valueType)                        *)
                  (*   enum(value1, value2, ...)                         *)
                  (*   literal(value)                                    *)
                  (*   lazy(ModelRef)                                    *)
                  (*                                                     *)
                  (* Any PascalCase IDENTIFIER may also be a model ref   *)

(* --------------------------------------------------------------------- *)
(* Type Arguments & Constraints                                          *)
(* --------------------------------------------------------------------- *)

typeArgs        = [ typeArg , { "," , typeArg } ] ;

typeArg         = IDENTIFIER , "=" , argValue           (* key=value     *)
                | STRING_LIT                            (* literal arg   *)
                | NUMBER_LIT
                | BOOLEAN_LIT
                | typeExpression ;                      (* nested type   *)

                  (* Known constraint keys:                              *)
                  (*   min=N, max=N    — value or length bounds          *)
                  (*   len=N           — exact length                    *)
                  (*   regex=/pattern/ — regex constraint                *)

argValue        = regexLiteral
                | IDENTIFIER
                | NUMBER_LIT
                | STRING_LIT
                | BOOLEAN_LIT ;

regexLiteral    = "/" , { regexChar } , "/" ;

regexChar       = ? any token except "/" ? ;
                  (* e.g. [a-z0-9-]+  →  letters, digits, metacharacters *)
                  (* Allows: identifiers, numbers, parens, pipes, braces *)
                  (*   brackets, question, equals, comma, colon,         *)
                  (*   plus, star, caret, backslash, dot                 *)

(* --------------------------------------------------------------------- *)
(* Inline Brace Objects                                                  *)
(* --------------------------------------------------------------------- *)

inlineBraceObject = "{" , { inlineField , [ "," ] } , "}" ;
                  (* commas between fields are optional                  *)

inlineField     = IDENTIFIER , [ "?" ] , ":" , typeExpression ,
                  [ "=" , defaultValue ] ;
                  (* supports optional default values                    *)

(* --------------------------------------------------------------------- *)
(* Default Values                                                        *)
(* --------------------------------------------------------------------- *)

defaultValue    = STRING_LIT
                | NUMBER_LIT
                | BOOLEAN_LIT
                | IDENTIFIER ;
                  (* .default(value) replaces .optional() — mutually     *)
                  (* exclusive with "?"                                   *)


(* ===================================================================== *)
(* Part 2 — Operation Grammar  (.op files)                              *)
(* ===================================================================== *)

opRoot          = [ frontMatter ] , { routeDecl } , EOF ;

(* --------------------------------------------------------------------- *)
(* Routes                                                                *)
(* --------------------------------------------------------------------- *)

routeDecl       = routePath , "{" , routeBody , "}" ;

routePath       = pathSegment , { pathSegment } ;
                  (* at least one segment required                       *)

pathSegment     = "/" , ( ":" , IDENTIFIER              (* param  :id    *)
                       | IDENTIFIER ) ;                 (* literal users  *)

(* --------------------------------------------------------------------- *)
(* Route Body                                                            *)
(* --------------------------------------------------------------------- *)

routeBody       = { paramsBlock | httpOperation } ;

(* --------------------------------------------------------------------- *)
(* Path Parameters                                                       *)
(* --------------------------------------------------------------------- *)

paramsBlock     = "params" , ":" , ( IDENTIFIER               (* type ref   *)
                                  | "{" , { paramDecl } , "}" ) ;  (* inline     *)

paramDecl       = IDENTIFIER , ":" , IDENTIFIER ;
                  (* first IDENTIFIER  = parameter name                  *)
                  (* second IDENTIFIER = parameter type                  *)

(* --------------------------------------------------------------------- *)
(* HTTP Operations                                                       *)
(* --------------------------------------------------------------------- *)

httpMethod      = "get" | "post" | "put" | "patch" | "delete" ;

httpOperation   = httpMethod , ":" , "{" , operationBody , "}" ;
                  (* colon and braces are mandatory                     *)

operationBody   = { serviceDecl | queryBlock | headersBlock
                  | requestBlock | responseBlock } ;

(* --------------------------------------------------------------------- *)
(* Service                                                               *)
(* --------------------------------------------------------------------- *)

serviceDecl     = "service" , ":" , IDENTIFIER ;
                  (* IDENTIFIER = dotted service reference                 *)
                  (* e.g. service: LedgerService.updateCategoryMembership  *)
                  (* class-only form: service: LedgerService               *)

(* --------------------------------------------------------------------- *)
(* Query Parameters                                                      *)
(* --------------------------------------------------------------------- *)

queryBlock      = "query" , ":" , opTypeExpr ;
                  (* type reference: query: Pagination                     *)
                  (* inline object:  query: { page: int, limit: int }      *)
                  (* intersection:   query: Pagination & { sortBy: string } *)

(* --------------------------------------------------------------------- *)
(* Headers                                                               *)
(* --------------------------------------------------------------------- *)

headersBlock    = "headers" , ":" , opTypeExpr ;
                  (* type reference: headers: CommonHeaders                *)
                  (* inline object:  headers: { authorization: string }    *)

(* --------------------------------------------------------------------- *)
(* Request                                                               *)
(* --------------------------------------------------------------------- *)

requestBlock    = "request" , ":" , "{" , contentTypeLine , "}" ;

(* --------------------------------------------------------------------- *)
(* Response                                                              *)
(* --------------------------------------------------------------------- *)

responseBlock   = "response" , ":" , "{" , { statusCodeBlock } , "}" ;

statusCodeBlock = NUMBER_LIT , ":" , [ "{" , contentTypeLine , "}" ] ;
                  (* NUMBER_LIT = HTTP status code (200, 201, 404, etc.) *)
                  (* body is optional — e.g. 204 has no content          *)

(* --------------------------------------------------------------------- *)
(* Content Type & Body                                                   *)
(* --------------------------------------------------------------------- *)

contentTypeLine = IDENTIFIER , "/" , IDENTIFIER , ":" ,
                  opTypeExpr ;
                  (* e.g. application/json: User                         *)
                  (* e.g. multipart/form-data: UploadInput               *)
                  (* e.g. application/json: array(User)                  *)

(* --------------------------------------------------------------------- *)
(* OP Type Expressions                                                   *)
(* --------------------------------------------------------------------- *)
(* These mirror the DTO type system but also support postfix array       *)
(* syntax ([]) on atomic types. Used in query, headers, request body,    *)
(* and response body positions.                                          *)

opTypeExpr      = opIntersectionExpr , { "|" , opIntersectionExpr } ;
                  (* union: string | number                              *)

opIntersectionExpr = opAtomicType , { "&" , opAtomicType } ;
                  (* intersection: Pagination & { sortBy: string }       *)

opAtomicType    = opInlineObject
                | IDENTIFIER , [ "(" , opTypeArgs , ")" ] ,
                  [ "[" , "]" ] ;
                  (* IDENTIFIER = type name or model reference           *)
                  (* optional parens for type args/constraints           *)
                  (* optional postfix [] for array shorthand             *)
                  (* e.g. User[], string(min=1)[], enum(a, b)            *)

(* --------------------------------------------------------------------- *)
(* OP Type Arguments                                                     *)
(* --------------------------------------------------------------------- *)

opTypeArgs      = [ opTypeArg , { "," , opTypeArg } ] ;

opTypeArg       = IDENTIFIER , "=" , opArgValue         (* key=value     *)
                | STRING_LIT                            (* literal arg   *)
                | NUMBER_LIT
                | BOOLEAN_LIT
                | opTypeExpr ;                          (* nested type   *)

opArgValue      = NUMBER_LIT
                | STRING_LIT
                | BOOLEAN_LIT
                | IDENTIFIER ;
                  (* Note: OP argValue does NOT support regex literals   *)
                  (* unlike DTO argValue                                 *)

(* --------------------------------------------------------------------- *)
(* OP Inline Objects                                                     *)
(* --------------------------------------------------------------------- *)

opInlineObject  = "{" , { opInlineField , [ "," ] } , "}" ;
                  (* commas between fields are optional                  *)

opInlineField   = IDENTIFIER , [ "?" ] , ":" , opTypeExpr ;
                  (* Note: OP inline fields do NOT support default values *)
                  (* unlike DTO inline fields                            *)
