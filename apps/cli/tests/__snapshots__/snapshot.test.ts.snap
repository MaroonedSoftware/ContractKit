exports[`OP snapshot tests > ledger.op matches snapshot 1`] = `
"import { z } from 'zod';
import { ServerKitRouter, bodyParserMiddleware } from '@maroonedsoftware/koa';
import { LedgerService } from '#src/modules/ledger/ledger.service.js';
import { AccountBalances, GetAccountBalancesQuery, LedgerAccount, LedgerCategory, LedgerTransaction, ListAccountTransactionsQuery, Pagination } from '#modules/ledger/types/index.js';
import { parseAndValidate } from '#src/shared/validator.js';

/**
 * generated from [ledger.op](file://.//Users/robert/projects/contract-dsl/contracts/operations/ledger.op)
*/
export const LedgerRouter = ServerKitRouter();

/**
 * from [ledger.op](file://.//Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L7)
*/
LedgerRouter.post('/ledger/accounts', bodyParserMiddleware(['json']), async (ctx, next) => {
    const body = await parseAndValidate(ctx.body, LedgerAccount);

    const service = ctx.container.get(LedgerService);
    const result: LedgerAccount = await service.createAccount(body);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * from [ledger.op](file://.//Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L18)
*/
LedgerRouter.get('/ledger/accounts', async (ctx, next) => {
    const query = await parseAndValidate(ctx.query, Pagination);

    const resultType = z.strictObject({
    meta: Pagination,
    data: z.array(LedgerAccount),
});
    const service = ctx.container.get(LedgerService);
    const result: z.infer<typeof resultType> = await service.listAccounts(query);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * from [ledger.op](file://.//Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L36)
*/
LedgerRouter.get('/ledger/accounts/:accountId', async (ctx, next) => {
    const { accountId } = await parseAndValidate(
        ctx.params,
        z.strictObject({
            accountId: z.uuid(),
        }),
    );

    const service = ctx.container.get(LedgerService);
    const result: LedgerAccount = await service.getAccount(accountId);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * from [ledger.op](file://.//Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L50)
*/
LedgerRouter.get('/ledger/accounts/:accountId/balances', async (ctx, next) => {
    const { accountId } = await parseAndValidate(
        ctx.params,
        z.strictObject({
            accountId: z.uuid(),
        }),
    );

    const query = await parseAndValidate(ctx.query, GetAccountBalancesQuery);

    const service = ctx.container.get(LedgerService);
    const result: AccountBalances = await service.getAccountBalances(accountId, query);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * from [ledger.op](file://.//Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L65)
*/
LedgerRouter.get('/ledger/accounts/:accountId/transactions', async (ctx, next) => {
    const { accountId } = await parseAndValidate(
        ctx.params,
        z.strictObject({
            accountId: z.uuid(),
        }),
    );

    const query = await parseAndValidate(ctx.query, ListAccountTransactionsQuery);

    const service = ctx.container.get(LedgerService);
    const result: LedgerTransaction[] = await service.listAccountTransactions(accountId, query);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * from [ledger.op](file://.//Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L80)
*/
LedgerRouter.get('/ledger/accounts/:accountId/categories', async (ctx, next) => {
    const { accountId } = await parseAndValidate(
        ctx.params,
        z.strictObject({
            accountId: z.uuid(),
        }),
    );

    const service = ctx.container.get(LedgerService);
    const result: LedgerCategory[] = await service.getAccountCategories(accountId);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * from [ledger.op](file://.//Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L95)
*/
LedgerRouter.put('/ledger/accounts/:accountId/categories/:categoryId', async (ctx, next) => {
    const { accountId, categoryId } = await parseAndValidate(
        ctx.params,
        z.strictObject({
            accountId: z.uuid(),
            categoryId: z.uuid(),
        }),
    );

    const service = ctx.container.get(LedgerService);
    await service.addAccountToCategory(accountId, categoryId);

    ctx.status = 204;

    await next();
});

/**
 * from [ledger.op](file://.//Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L101)
*/
LedgerRouter.delete('/ledger/accounts/:accountId/categories/:categoryId', async (ctx, next) => {
    const { accountId, categoryId } = await parseAndValidate(
        ctx.params,
        z.strictObject({
            accountId: z.uuid(),
            categoryId: z.uuid(),
        }),
    );

    const service = ctx.container.get(LedgerService);
    await service.removeAccountFromCategory(accountId, categoryId);

    ctx.status = 204;

    await next();
});
"
`;

exports[`OP snapshot tests > transfers.op matches snapshot 1`] = `
"import { z } from 'zod';
import { ServerKitRouter, bodyParserMiddleware } from '@maroonedsoftware/koa';
import { TransfersService } from '#src/modules/transfers/transfers.service.js';
import { Counterparty, Pagination } from '#modules/transfers/types/index.js';
import { parseAndValidate } from '#src/shared/validator.js';

/**
 * generated from [transfers.op](file://.//Users/robert/projects/contract-dsl/contracts/operations/transfers.op)
*/
export const TransfersRouter = ServerKitRouter();

/**
 * list counterparties
 * from [transfers.op](file://.//Users/robert/projects/contract-dsl/contracts/operations/transfers.op#L20)
*/
TransfersRouter.get('/transfers/counterparties', async (ctx, next) => {
    const query = await parseAndValidate(ctx.query, Pagination);

    const resultType = z.strictObject({
    pagination: Pagination,
    data: z.array(Counterparty),
});
    const service = ctx.container.get(TransfersService);
    const result: z.infer<typeof resultType> = await service.listCounterparties(query);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});
"
`;
