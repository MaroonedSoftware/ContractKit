exports[`DTO snapshot tests > counterparty.dto matches snapshot 1`] = `
"import { z } from 'zod';
import { DateTime } from 'luxon';
import { CounterpartyAccount } from './counterparty.account.dto.js';
import { CreateCounterpartyFinancialAccount } from './create.counterparty.financial.account.dto.js';
import { CreateCounterpartyProcessorAccount } from './create.counterparty.processor.account.dto.js';

/**
 * generated from [Counterparty](file:///Users/robert/projects/contract-dsl/contracts/types/modules/transfers/counterparty.dto#L1)
*/
const CounterpartyBase = z.strictObject({
    createdAt: z.custom<DateTime>((val) => val instanceof DateTime, { error: 'Must be in ISO 8601 format' }).describe("The counterparty creation timestamp"),
    updatedAt: z.custom<DateTime>((val) => val instanceof DateTime, { error: 'Must be in ISO 8601 format' }).describe("The counterparty creation timestamp"),
    id: z.uuid().describe("The counterparty last update timestamp"),
    name: z.string().min(1).max(100).describe("The counterparty identifier"),
    email: z.email().optional().describe("The counterparty name"),
    active: z.boolean().default(true).describe("The counterparty email"),
    accounts: z.array(CounterpartyAccount).describe("Whether the counterparty is active"),
});

export const Counterparty = z.strictObject({
    createdAt: z.custom<DateTime>((val) => val instanceof DateTime, { error: 'Must be in ISO 8601 format' }).describe("The counterparty creation timestamp"),
    updatedAt: z.custom<DateTime>((val) => val instanceof DateTime, { error: 'Must be in ISO 8601 format' }).describe("The counterparty creation timestamp"),
    id: z.uuid().describe("The counterparty last update timestamp"),
    name: z.string().min(1).max(100).describe("The counterparty identifier"),
    email: z.email().optional().describe("The counterparty name"),
    active: z.boolean().default(true).describe("The counterparty email"),
    accounts: z.array(CounterpartyAccount).describe("Whether the counterparty is active"),
});
export type Counterparty = z.infer<typeof Counterparty>;

export const CounterpartyInput = z.strictObject({
    name: z.string().min(1).max(100).describe("The counterparty identifier"),
    email: z.email().optional().describe("The counterparty name"),
    active: z.boolean().default(true).describe("The counterparty email"),
});
export type CounterpartyInput = z.infer<typeof CounterpartyInput>;

/**
 * generated from [CreateCounterparty](file:///Users/robert/projects/contract-dsl/contracts/types/modules/transfers/counterparty.dto#L11)
*/
export const CreateCounterparty = z.strictObject({
    name: z.string().min(1).max(100).describe("The counterparty name"),
    email: z.email().optional().describe("The counterparty name"),
    accounts: z.array(z.union([CreateCounterpartyFinancialAccount, CreateCounterpartyProcessorAccount])).min(0).max(10).describe("The counterparty email"),
});
export type CreateCounterparty = z.infer<typeof CreateCounterparty>;
"
`;

exports[`DTO snapshot tests > ledger.account.dto matches snapshot 1`] = `
"import { z } from 'zod';
import { DateTime } from 'luxon';
import { CustomCurrency } from './custom.currency.dto.js';

/**
 * generated from [LedgerAccount](file:///Users/robert/projects/contract-dsl/contracts/types/modules/ledger/ledger.account.dto#L1)
*/
const LedgerAccountBase = z.strictObject({
    id: z.uuid().describe("The account identifier"),
    name: z.string().min(3).max(100).describe("The account identifier"),
    normality: z.enum(["credit", "debit"]).describe("Account name"),
    currency: z.union([z.string().length(3), CustomCurrency]).default("USD").describe("Account normality"),
    description: z.string().max(1024).optional().describe("Currency code or custom currency"),
    createdAt: z.custom<DateTime>((val) => val instanceof DateTime, { error: 'Must be in ISO 8601 format' }).describe("Optional account description"),
    updatedAt: z.custom<DateTime>((val) => val instanceof DateTime, { error: 'Must be in ISO 8601 format' }).describe("The account creation date"),
    version: z.int().describe("The account last update date"),
});

export const LedgerAccount = z.strictObject({
    id: z.uuid().describe("The account identifier"),
    name: z.string().min(3).max(100).describe("The account identifier"),
    normality: z.enum(["credit", "debit"]).describe("Account name"),
    currency: z.union([z.string().length(3), CustomCurrency]).default("USD").describe("Account normality"),
    description: z.string().max(1024).optional().describe("Currency code or custom currency"),
    createdAt: z.custom<DateTime>((val) => val instanceof DateTime, { error: 'Must be in ISO 8601 format' }).describe("Optional account description"),
    updatedAt: z.custom<DateTime>((val) => val instanceof DateTime, { error: 'Must be in ISO 8601 format' }).describe("The account creation date"),
    version: z.int().describe("The account last update date"),
});
export type LedgerAccount = z.infer<typeof LedgerAccount>;

export const LedgerAccountInput = z.strictObject({
    name: z.string().min(3).max(100).describe("The account identifier"),
    normality: z.enum(["credit", "debit"]).describe("Account name"),
    currency: z.union([z.string().length(3), CustomCurrency]).default("USD").describe("Account normality"),
    description: z.string().max(1024).optional().describe("Currency code or custom currency"),
});
export type LedgerAccountInput = z.infer<typeof LedgerAccountInput>;
"
`;

