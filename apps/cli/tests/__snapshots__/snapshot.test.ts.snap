"import { z } from 'zod';
import { DateTime } from 'luxon';

/**
 * Represents a counterparty account
 * generated from [CounterpartyAccount](file://.//Users/robert/projects/contract-dsl/contracts/types/modules/transfers/counterparty.dto#L21)
*/
const CounterpartyAccountBase = z.strictObject({
    createdAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).describe("The counterparty account creation timestamp"),
    updatedAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).describe("The counterparty account last update timestamp"),
    id: z.uuid().describe("The counterparty account identifier"),
    counterpartyId: z.uuid().describe("The counterparty identifier"),
    financialInstitutionId: z.uuid().describe("The financial institution identifier"),
    active: z.boolean().default(true).describe("Whether the counterparty account is active"),
    accountNumber: z.string().min(3).max(60).describe("The account number"),
    accountNumberType: z.enum(["checking", "savings", "other"]).describe("The account number type"),
    accountName: z.string().min(3).max(100).optional().describe("The account name"),
    accountType: z.enum(["consumer", "commercial"]).describe("The account type"),
    verifiedAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).optional().describe("The date the account was verified"),
    verificationMethod: z.string().min(3).max(100).optional().describe("The verification method"),
});

export const CounterpartyAccount = z.strictObject({
    createdAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).describe("The counterparty account creation timestamp"),
    updatedAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).describe("The counterparty account last update timestamp"),
    id: z.uuid().describe("The counterparty account identifier"),
    counterpartyId: z.uuid().describe("The counterparty identifier"),
    financialInstitutionId: z.uuid().describe("The financial institution identifier"),
    active: z.boolean().default(true).describe("Whether the counterparty account is active"),
    accountNumber: z.string().min(3).max(60).describe("The account number"),
    accountNumberType: z.enum(["checking", "savings", "other"]).describe("The account number type"),
    accountName: z.string().min(3).max(100).optional().describe("The account name"),
    accountType: z.enum(["consumer", "commercial"]).describe("The account type"),
    verifiedAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).optional().describe("The date the account was verified"),
    verificationMethod: z.string().min(3).max(100).optional().describe("The verification method"),
});
export type CounterpartyAccount = z.infer<typeof CounterpartyAccount>;

export const CounterpartyAccountInput = z.strictObject({
    active: z.boolean().default(true).describe("Whether the counterparty account is active"),
    accountNumber: z.string().min(3).max(60).describe("The account number"),
    accountNumberType: z.enum(["checking", "savings", "other"]).describe("The account number type"),
    accountName: z.string().min(3).max(100).optional().describe("The account name"),
    accountType: z.enum(["consumer", "commercial"]).describe("The account type"),
});
export type CounterpartyAccountInput = z.infer<typeof CounterpartyAccountInput>;

/**
 * Represents a request to create a counterparty financial account
 * generated from [CreateCounterpartyFinancialAccount](file://.//Users/robert/projects/contract-dsl/contracts/types/modules/transfers/counterparty.dto#L36)
*/
export const CreateCounterpartyFinancialAccount = z.strictObject({
    active: z.boolean().default(true).describe("Whether the counterparty account is active"),
    routingNumber: z.string().min(3).max(60).describe("The routing number"),
    accountNumber: z.string().min(3).max(60).describe("The account number"),
    accountNumberType: z.enum(["checking", "savings", "other"]).default("checking").describe("The account number type"),
    accountName: z.string().min(3).max(100).optional().describe("The account name"),
    accountType: z.enum(["consumer", "commercial"]).default("commercial").describe("The account type"),
});
export type CreateCounterpartyFinancialAccount = z.infer<typeof CreateCounterpartyFinancialAccount>;

/**
 * Represents a request to create a counterparty processor account
 * generated from [CreateCounterpartyProcessorAccount](file://.//Users/robert/projects/contract-dsl/contracts/types/modules/transfers/counterparty.dto#L45)
*/
const CreateCounterpartyProcessorAccountBase = z.strictObject({
    active: z.boolean().default(true).describe("Whether the counterparty account is active"),
    processorToken: z.string().min(3).max(100).describe("The processor token"),
    processor: z.enum(["plaid"]).describe("The processor"),
});

export const CreateCounterpartyProcessorAccount = z.strictObject({
    active: z.boolean().default(true).describe("Whether the counterparty account is active"),
    processorToken: z.string().min(3).max(100).describe("The processor token"),
    processor: z.enum(["plaid"]).describe("The processor"),
});
export type CreateCounterpartyProcessorAccount = z.infer<typeof CreateCounterpartyProcessorAccount>;

export const CreateCounterpartyProcessorAccountInput = z.strictObject({
    active: z.boolean().default(true).describe("Whether the counterparty account is active"),
    processor: z.enum(["plaid"]).describe("The processor"),
});
export type CreateCounterpartyProcessorAccountInput = z.infer<typeof CreateCounterpartyProcessorAccountInput>;

/**
 * Represents a counterparty
 * generated from [Counterparty](file://.//Users/robert/projects/contract-dsl/contracts/types/modules/transfers/counterparty.dto#L5)
*/
const CounterpartyBase = z.strictObject({
    createdAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).describe("The counterparty creation timestamp"),
    updatedAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).describe("The counterparty last update timestamp"),
    id: z.uuid().describe("The counterparty identifier"),
    name: z.string().min(1).max(100).describe("The counterparty name"),
    email: z.email().optional().describe("The counterparty email"),
    active: z.boolean().default(true).describe("Whether the counterparty is active"),
    accounts: z.array(CounterpartyAccount).describe("The counterparty accounts"),
});

export const Counterparty = z.strictObject({
    createdAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).describe("The counterparty creation timestamp"),
    updatedAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).describe("The counterparty last update timestamp"),
    id: z.uuid().describe("The counterparty identifier"),
    name: z.string().min(1).max(100).describe("The counterparty name"),
    email: z.email().optional().describe("The counterparty email"),
    active: z.boolean().default(true).describe("Whether the counterparty is active"),
    accounts: z.array(CounterpartyAccount).describe("The counterparty accounts"),
});
export type Counterparty = z.infer<typeof Counterparty>;

export const CounterpartyInput = z.strictObject({
    name: z.string().min(1).max(100).describe("The counterparty name"),
    email: z.email().optional().describe("The counterparty email"),
    active: z.boolean().default(true).describe("Whether the counterparty is active"),
});
export type CounterpartyInput = z.infer<typeof CounterpartyInput>;

/**
 * Represents a request to create a counterparty
 * generated from [CreateCounterparty](file://.//Users/robert/projects/contract-dsl/contracts/types/modules/transfers/counterparty.dto#L15)
*/
const CreateCounterpartyBase = z.strictObject({
    name: z.string().min(1).max(100).describe("The counterparty name"),
    email: z.email().optional().describe("The counterparty email"),
    accounts: z.array(z.union([CreateCounterpartyFinancialAccount, CreateCounterpartyProcessorAccount])).min(0).max(10).describe("The counterparty accounts"),
});

export const CreateCounterparty = z.strictObject({
    name: z.string().min(1).max(100).describe("The counterparty name"),
    email: z.email().optional().describe("The counterparty email"),
    accounts: z.array(z.union([CreateCounterpartyFinancialAccount, CreateCounterpartyProcessorAccount])).min(0).max(10).describe("The counterparty accounts"),
});
export type CreateCounterparty = z.infer<typeof CreateCounterparty>;

export const CreateCounterpartyInput = z.strictObject({
    name: z.string().min(1).max(100).describe("The counterparty name"),
    email: z.email().optional().describe("The counterparty email"),
    accounts: z.array(z.union([CreateCounterpartyFinancialAccount, CreateCounterpartyProcessorAccountInput])).min(0).max(10).describe("The counterparty accounts"),
});
export type CreateCounterpartyInput = z.infer<typeof CreateCounterpartyInput>;
"
`;

exports[`DTO snapshot tests > ledger.account.dto matches snapshot 1`] = `
"import { z } from 'zod';
import { DateTime } from 'luxon';
import { CustomCurrency } from './custom.currency.js';
import { Pagination } from './pagination.js';

/**
 * Represents a ledger account
 * generated from [LedgerAccount](file://.//Users/robert/projects/contract-dsl/contracts/types/modules/ledger/ledger.account.dto#L5)
*/
const LedgerAccountBase = z.strictObject({
    id: z.uuid().describe("The ledger account identifier"),
    name: z.string().min(3).max(100).describe("The ledger account name"),
    normality: z.enum(["credit", "debit"]).describe("The ledger account normality"),
    currency: z.union([z.string().length(3), CustomCurrency]).default("USD").describe("The ledger account currency code or custom currency"),
    exponent: z.coerce.number().int().describe("The ledger account currency exponent"),
    description: z.string().max(1024).optional().describe("The ledger account description"),
    createdAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).describe("The ledger account creation date"),
    updatedAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).describe("The ledger account last update date"),
    version: z.coerce.number().int().describe("The ledger account version"),
});

export const LedgerAccount = z.strictObject({
    id: z.uuid().describe("The ledger account identifier"),
    name: z.string().min(3).max(100).describe("The ledger account name"),
    normality: z.enum(["credit", "debit"]).describe("The ledger account normality"),
    currency: z.union([z.string().length(3), CustomCurrency]).default("USD").describe("The ledger account currency code or custom currency"),
    exponent: z.coerce.number().int().describe("The ledger account currency exponent"),
    description: z.string().max(1024).optional().describe("The ledger account description"),
    createdAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).describe("The ledger account creation date"),
    updatedAt: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).describe("The ledger account last update date"),
    version: z.coerce.number().int().describe("The ledger account version"),
});
export type LedgerAccount = z.infer<typeof LedgerAccount>;

export const LedgerAccountInput = z.strictObject({
    name: z.string().min(3).max(100).describe("The ledger account name"),
    normality: z.enum(["credit", "debit"]).describe("The ledger account normality"),
    currency: z.union([z.string().length(3), CustomCurrency]).default("USD").describe("The ledger account currency code or custom currency"),
    description: z.string().max(1024).optional().describe("The ledger account description"),
});
export type LedgerAccountInput = z.infer<typeof LedgerAccountInput>;

/**
 * Represents a query to get ledger account balances
 * generated from [GetAccountBalancesQuery](file://.//Users/robert/projects/contract-dsl/contracts/types/modules/ledger/ledger.account.dto#L17)
*/
export const GetAccountBalancesQuery = z.strictObject({
    date: z.preprocess((val) => typeof val === 'string' ? DateTime.fromISO(val) : val, z.custom<DateTime>((val) => val instanceof DateTime && val.isValid, { message: 'Must be in ISO 8601 format' })).optional().describe("Optional ISO 8601 date to query balances at"),
    version: z.coerce.number().int().min(0).optional().describe("Optional ledger account version to query balances at"),
});
export type GetAccountBalancesQuery = z.infer<typeof GetAccountBalancesQuery>;

/**
 * Represents the balances of a ledger account
 * generated from [AccountBalances](file://.//Users/robert/projects/contract-dsl/contracts/types/modules/ledger/ledger.account.dto#L22)
*/
export const AccountBalances = z.strictObject({
    postedBalance: z.bigint().min(0n).describe("The posted balance in smallest currency units"),
    pendingBalance: z.bigint().min(0n).describe("The pending balance in smallest currency units"),
    availableBalance: z.bigint().min(0n).describe("The available balance in smallest currency units"),
});
export type AccountBalances = z.infer<typeof AccountBalances>;

/**
 * Represents a query to list ledger account transactions
 * generated from [ListAccountTransactionsQuery](file://.//Users/robert/projects/contract-dsl/contracts/types/modules/ledger/ledger.account.dto#L28)
*/
export const ListAccountTransactionsQuery = Pagination.extend({
    status: z.enum(["pending", "posted", "archived"]).optional(),
    sortBy: z.enum(["effective_at", "created_at", "id"]).default("effective_at"),
});
export type ListAccountTransactionsQuery = z.infer<typeof ListAccountTransactionsQuery>;
"
`;

