exports[`OP snapshot tests > ledger.op matches snapshot 1`] = `
"import { z } from 'zod';
import { ServerKitRouter, bodyParserMiddleware } from '@maroonedsoftware/koa';
import { LedgerService } from '#modules/ledger/ledger.service.js';
import { AccountBalances, GetAccountBalancesQuery, LedgerAccount, LedgerAccountInput, LedgerCategory, LedgerTransaction, ListAccountTransactionsQuery, PaginationQuery } from '#modules/ledger/types/index.js';
import { parseAndValidate } from '#src/shared/validator.js';

/**
 * generated from [ledger.op](file:///Users/robert/projects/contract-dsl/contracts/operations/ledger.op)
*/
export const LedgerRouter = ServerKitRouter();

/**
 * from file:///Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L2
*/
LedgerRouter.post('/ledger/accounts', bodyParserMiddleware(['json']), async (ctx, next) => {
    const body = await parseAndValidate(ctx.body, LedgerAccountInput);

    const service = ctx.container.get(LedgerService);
    const result: LedgerAccount = await service.create(body);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * from file:///Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L12
*/
LedgerRouter.get('/ledger/accounts', async (ctx, next) => {
    const query = await parseAndValidate(ctx.query, PaginationQuery);

    const service = ctx.container.get(LedgerService);
    const result: LedgerAccount[] = await service.list(query);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * from file:///Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L26
*/
LedgerRouter.get('/ledger/accounts/:accountId', async (ctx, next) => {
    const { accountId } = await parseAndValidate(
        ctx.params,
        z.strictObject({
            accountId: z.uuid(),
        }),
    );

    const service = ctx.container.get(LedgerService);
    const result: LedgerAccount = await service.getById(accountId);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * from file:///Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L39
*/
LedgerRouter.get('/ledger/accounts/:accountId/balances', async (ctx, next) => {
    const { accountId } = await parseAndValidate(
        ctx.params,
        z.strictObject({
            accountId: z.uuid(),
        }),
    );

    const query = await parseAndValidate(ctx.query, GetAccountBalancesQuery);

    const service = ctx.container.get(LedgerService);
    const result: AccountBalances = await service.getById(accountId, query);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * from file:///Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L53
*/
LedgerRouter.get('/ledger/accounts/:accountId/transactions', async (ctx, next) => {
    const { accountId } = await parseAndValidate(
        ctx.params,
        z.strictObject({
            accountId: z.uuid(),
        }),
    );

    const query = await parseAndValidate(ctx.query, ListAccountTransactionsQuery);

    const service = ctx.container.get(LedgerService);
    const result: LedgerTransaction[] = await service.getById(accountId, query);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * from file:///Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L67
*/
LedgerRouter.get('/ledger/accounts/:accountId/categories', async (ctx, next) => {
    const { accountId } = await parseAndValidate(
        ctx.params,
        z.strictObject({
            accountId: z.uuid(),
        }),
    );

    const service = ctx.container.get(LedgerService);
    const result: LedgerCategory[] = await service.getById(accountId);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * from file:///Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L81
*/
LedgerRouter.put('/ledger/accounts/:accountId/categories/:categoryId', async (ctx, next) => {
    const { accountId, categoryId } = await parseAndValidate(
        ctx.params,
        z.strictObject({
            accountId: z.uuid(),
            categoryId: z.uuid(),
        }),
