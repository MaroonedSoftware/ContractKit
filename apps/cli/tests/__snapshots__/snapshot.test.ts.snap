    const service = ctx.container.get(LedgerService);
    const result: LedgerAccount = await service.updateCategoryMembership(accountId, categoryId);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * from file:///Users/robert/projects/contract-dsl/contracts/operations/ledger.op#L89
*/
LedgerRouter.delete('/ledger/accounts/:accountId/categories/:categoryId', async (ctx, next) => {
    const { accountId, categoryId } = await parseAndValidate(
        ctx.params,
        z.strictObject({
            accountId: z.uuid(),
            categoryId: z.uuid(),
        }),
    );

    const service = ctx.container.get(LedgerService);
    await service.updateCategoryMembership(accountId, categoryId);

    ctx.status = 204;

    await next();
});
"
`;

exports[`OP snapshot tests > transfers.op matches snapshot 1`] = `
"import { z } from 'zod';
import { ServerKitRouter, bodyParserMiddleware } from '@maroonedsoftware/koa';
import { TransfersService } from '#modules/transfers/transfers.service.js';
import { Counterparty, CreateCounterparty, Pagination } from '#modules/transfers/types/index.js';
import { parseAndValidate } from '#src/shared/validator.js';

/**
 * generated from [transfers.op](file:///Users/robert/projects/contract-dsl/contracts/operations/transfers.op)
*/
export const TransfersRouter = ServerKitRouter();

/**
 * list counterparties
 * from file:///Users/robert/projects/contract-dsl/contracts/operations/transfers.op#L15
*/
TransfersRouter.get('/transfers/counterparties', async (ctx, next) => {
    const query = await parseAndValidate(ctx.query, Pagination);

    const service = ctx.container.get(TransfersService);
    const result: z.infer<typeof z.strictObject({
    pagination: Pagination,
    data: z.array(Counterparty),
})> = await service.listCounterparties(query);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

/**
 * create counterparty
 * from file:///Users/robert/projects/contract-dsl/contracts/operations/transfers.op#L24
*/
TransfersRouter.post('/transfers/counterparties', bodyParserMiddleware(['json']), async (ctx, next) => {
    const body = await parseAndValidate(ctx.body, CreateCounterparty);

    const service = ctx.container.get(TransfersService);
    const result: Counterparty = await service.create(body);

    ctx.status = 201;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});
"
`;
