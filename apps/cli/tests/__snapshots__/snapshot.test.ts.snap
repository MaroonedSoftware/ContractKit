"import { z } from 'zod';
import { ServerKitRouter, bodyParserMiddleware } from '@maroonedsoftware/koa';
import { TransfersService } from '#modules/transfers/transfers.service.js';
import { CreateTransferIntent, Pagination, Routing, TransferIntent } from '#modules/transfers/types/index.js';
import { parseAndValidate } from '#src/shared/validator.js';

export const TransfersRouter = ServerKitRouter();

// from /transfers/fi POST (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/operations/transfers.op:2)
TransfersRouter.post('/transfers/fi', bodyParserMiddleware(['json']), async (ctx, next) => {
    const body = await parseAndValidate(ctx.body, Routing);

    const service = ctx.container.get(TransfersService);
    const result: Routing = await service.create(body);

    ctx.status = 201;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

// from /transfers POST (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/operations/transfers.op:15)
TransfersRouter.post('/transfers', bodyParserMiddleware(['json']), async (ctx, next) => {
    const body = await parseAndValidate(ctx.body, CreateTransferIntent);

    const service = ctx.container.get(TransfersService);
    const result: TransferIntent = await service.handle(body);

    ctx.status = 201;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

// from /transfers GET (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/operations/transfers.op:26)
TransfersRouter.get('/transfers', async (ctx, next) => {
    const query = await parseAndValidate(ctx.query, Pagination);

    const service = ctx.container.get(TransfersService);
    const result: TransferIntent[] = await service.handle();

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

// from /transfers/:id GET (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/operations/transfers.op:38)
TransfersRouter.get('/transfers/:id', async (ctx, next) => {
    const service = ctx.container.get(TransfersService);
    const result: TransferIntent = await service.getIntent();

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});


// Register in apps/api/src/routes/routes.setup.ts:
