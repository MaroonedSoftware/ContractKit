exports[`OP snapshot tests > ledger.op matches snapshot 1`] = `
"import { z } from 'zod';
import { ServerKitRouter, bodyParserMiddleware } from '@maroonedsoftware/koa';
import { LedgerService } from '#modules/ledger/ledger.service.js';
import { AccountBalances, GetAccountBalancesQuery, LedgerAccount, LedgerCategory, LedgerTransaction, ListAccountTransactionsQuery, PaginationQuery } from '#modules/ledger/types/index.js';
import { parseAndValidate } from '#src/shared/validator.js';

export const LedgerRouter = ServerKitRouter();

// from /ledger/accounts POST (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/operations/ledger.op:2)
LedgerRouter.post('/ledger/accounts', bodyParserMiddleware(['json']), async (ctx, next) => {
    const body = await parseAndValidate(ctx.body, LedgerAccount);

    const service = ctx.container.get(LedgerService);
    const result: LedgerAccount = await service.create(body);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

// from /ledger/accounts GET (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/operations/ledger.op:12)
LedgerRouter.get('/ledger/accounts', async (ctx, next) => {
    const query = await parseAndValidate(ctx.query, PaginationQuery);

    const service = ctx.container.get(LedgerService);
    const result: LedgerAccount[] = await service.list();

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

// from /ledger/accounts/:accountId GET (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/operations/ledger.op:23)
LedgerRouter.get('/ledger/accounts/:accountId', async (ctx, next) => {
    const service = ctx.container.get(LedgerService);
    const result: LedgerAccount = await service.getById();

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

// from /ledger/accounts/:accountId/balances GET (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/operations/ledger.op:36)
LedgerRouter.get('/ledger/accounts/:accountId/balances', async (ctx, next) => {
    const { accountId } = await parseAndValidate(
        ctx.params,
        z.strictObject({
            accountId: z.uuid(),
        }),
    );

    const query = await parseAndValidate(ctx.query, GetAccountBalancesQuery);

    const service = ctx.container.get(LedgerService);
    const result: AccountBalances = await service.getById(accountId);

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

// from /ledger/accounts/:accountId/transactions GET (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/operations/ledger.op:47)
LedgerRouter.get('/ledger/accounts/:accountId/transactions', async (ctx, next) => {
    const query = await parseAndValidate(ctx.query, ListAccountTransactionsQuery);

    const service = ctx.container.get(LedgerService);
    const result: LedgerTransaction[] = await service.getById();

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

// from /ledger/accounts/:accountId/categories GET (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/operations/ledger.op:58)
LedgerRouter.get('/ledger/accounts/:accountId/categories', async (ctx, next) => {
    const service = ctx.container.get(LedgerService);
    const result: LedgerCategory[] = await service.getById();

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

// from /ledger/accounts/:accountId/categories/:categoryId PUT (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/operations/ledger.op:68)
LedgerRouter.put('/ledger/accounts/:accountId/categories/:categoryId', async (ctx, next) => {
    const service = ctx.container.get(LedgerService);
    const result: LedgerAccount = await service.updateCategoryMembership();

    ctx.status = 200;
    ctx.type = 'application/json';
    ctx.body = result;

    await next();
});

// from /ledger/accounts/:accountId/categories/:categoryId DELETE (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/operations/ledger.op:76)
LedgerRouter.delete('/ledger/accounts/:accountId/categories/:categoryId', async (ctx, next) => {
    const service = ctx.container.get(LedgerService);
    await service.updateCategoryMembership();

    ctx.status = 204;

    await next();
});


// Register in apps/api/src/routes/routes.setup.ts:
// import { LedgerRouter } from './ledger.router';
// server.use(LedgerRouter.routes()).use(LedgerRouter.allowedMethods());"
`;

