"import { z } from 'zod';
import { CounterpartyAccount } from './counterparty.account.dto.js';

// from Counterparty (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/types/modules/transfers/counterparty.dto:1)
const CounterpartyBase = z.strictObject({
    id: z.uuid().describe("The counterparty identifier"),
    name: z.string().min(1).max(100).describe("The counterparty identifier"),
    email: z.email().optional().describe("The counterparty name"),
    active: z.boolean().default(true).describe("The counterparty email"),
    accounts: z.array(CounterpartyAccount).describe("Whether the counterparty is active"),
});

export const Counterparty = z.strictObject({
    id: z.uuid().describe("The counterparty identifier"),
    name: z.string().min(1).max(100).describe("The counterparty identifier"),
    email: z.email().optional().describe("The counterparty name"),
    active: z.boolean().default(true).describe("The counterparty email"),
    accounts: z.array(CounterpartyAccount).describe("Whether the counterparty is active"),
});
export type Counterparty = z.infer<typeof Counterparty>;

export const CounterpartyInput = z.strictObject({
    name: z.string().min(1).max(100).describe("The counterparty identifier"),
    email: z.email().optional().describe("The counterparty name"),
    active: z.boolean().default(true).describe("The counterparty email"),
    accounts: z.array(CounterpartyAccount).describe("Whether the counterparty is active"),
});
export type CounterpartyInput = z.infer<typeof CounterpartyInput>;
"
`;

exports[`DTO snapshot tests > ledger.account.dto matches snapshot 1`] = `
"import { z } from 'zod';
import { DateTime } from 'luxon';

// from CustomCurrency (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/types/modules/ledger/ledger.account.dto:1)
export const CustomCurrency = z.strictObject({
    code: z.string().length(3).describe("ISO currency code"),
    exponent: z.int().describe("ISO currency code"),
});
export type CustomCurrency = z.infer<typeof CustomCurrency>;

// from LedgerAccount (/Users/robert/projects/contract-dsl/.auto-claude/worktrees/tasks/002-update-cli-and-lsp-with-grammar/contracts/types/modules/ledger/ledger.account.dto:6)
const LedgerAccountBase = z.strictObject({
    id: z.uuid().describe("The account identifier"),
    name: z.string().min(3).max(100).describe("The account identifier"),
    normality: z.enum(["credit", "debit"]).describe("Account name"),
    currency: z.union([z.string().length(3), CustomCurrency]).default("USD").describe("Account normality"),
    description: z.string().max(1024).optional().describe("Currency code or custom currency"),
    createdAt: z.custom<DateTime>((val) => val instanceof DateTime, { error: 'Must be a Luxon DateTime' }).describe("Optional account description"),
    updatedAt: z.custom<DateTime>((val) => val instanceof DateTime, { error: 'Must be a Luxon DateTime' }).describe("The account creation date"),
    version: z.int().describe("The account last update date"),
});

export const LedgerAccount = z.strictObject({
    id: z.uuid().describe("The account identifier"),
    name: z.string().min(3).max(100).describe("The account identifier"),
    normality: z.enum(["credit", "debit"]).describe("Account name"),
    currency: z.union([z.string().length(3), CustomCurrency]).default("USD").describe("Account normality"),
    description: z.string().max(1024).optional().describe("Currency code or custom currency"),
    createdAt: z.custom<DateTime>((val) => val instanceof DateTime, { error: 'Must be a Luxon DateTime' }).describe("Optional account description"),
    updatedAt: z.custom<DateTime>((val) => val instanceof DateTime, { error: 'Must be a Luxon DateTime' }).describe("The account creation date"),
    version: z.int().describe("The account last update date"),
});
export type LedgerAccount = z.infer<typeof LedgerAccount>;

export const LedgerAccountInput = z.strictObject({
    name: z.string().min(3).max(100).describe("The account identifier"),
    normality: z.enum(["credit", "debit"]).describe("Account name"),
    currency: z.union([z.string().length(3), CustomCurrency]).default("USD").describe("Account normality"),
    description: z.string().max(1024).optional().describe("Currency code or custom currency"),
});
export type LedgerAccountInput = z.infer<typeof LedgerAccountInput>;
"
`;

