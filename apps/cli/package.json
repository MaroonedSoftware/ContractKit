{
    "name": "contract-dsl",
    "version": "0.1.0",
    "description": "Compiler for .dto and .op DSL files into TypeScript/Zod/Koa code",
    "type": "module",
    "main": "index.ts",
    "exports": {
        "./src/parser-dto.js": "./dist/parser-dto.js",
        "./src/parser-op.js": "./dist/parser-op.js",
        "./src/validate-op.js": "./dist/validate-op.js",
        "./src/diagnostics.js": "./dist/diagnostics.js",
        "./src/ast.js": "./dist/ast.js"
    },
    "bin": {
        "dsl-compile": "dist/cli.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "node --inspect --no-warnings --no-deprecation --import @swc-node/register/esm-register --enable-source-maps --watch --watch-preserve-output ./src/index.ts",
        "lint": "eslint --fix",
        "format": "prettier --write .",
        "test": "vitest run",
        "start": "node dist/cli.js \"/Users/robert/projects/contract-dsl/contracts/**/*.{dto,op}\" --out-dir ./out/"
    },
    "dependencies": {
        "chevrotain": "^11.1.1",
        "glob": "^13.0.6"
    },
    "devDependencies": {
        "@repo/config-eslint": "workspace:*",
        "@repo/config-typescript": "workspace:*"
    }
}
