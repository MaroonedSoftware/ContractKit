{
    "name": "@contractkit/cli",
    "version": "0.6.0",
    "description": "Compiler for .ck files",
    "author": {
        "name": "Marooned Software",
        "url": "https://github.com/MaroonedSoftware/contractkit"
    },
    "bugs": {
        "url": "https://github.com/MaroonedSoftware/contractkit/issues"
    },
    "homepage": "https://github.com/MaroonedSoftware/contractkit/packages/cli#readme",
    "keywords": [
        "contractkit",
        "cli",
        "compiler",
        "dsl",
        "contract"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/MaroonedSoftware/contractkit.git"
    },
    "type": "module",
    "main": "./dist/cli.js",
    "bin": {
        "contractkit": "dist/cli.js"
    },
    "scripts": {
        "build": "tsup src/cli.ts --format esm --sourcemap",
        "build:ci": "eslint --max-warnings=0 && pnpm run build",
        "dev": "node --inspect --no-warnings --no-deprecation --import @swc-node/register/esm-register --enable-source-maps --watch --watch-preserve-output ./src/index.ts",
        "lint": "eslint --fix",
        "format": "prettier --write .",
        "test": "vitest run",
        "test:ci": "vitest run --coverage",
        "start": "node dist/cli.js"
    },
    "dependencies": {
        "@contractkit/core": "workspace:*",
        "@contractkit/openapi-to-ck": "workspace:*",
        "glob": "^13.0.6"
    },
    "peerDependencies": {
        "prettier": ">=3.0.0"
    },
    "peerDependenciesMeta": {
        "prettier": {
            "optional": true
        }
    },
    "devDependencies": {
        "@repo/config-eslint": "workspace:*",
        "@repo/config-typescript": "workspace:*"
    }
}
