{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Contract DSL Operations",
    "scopeName": "source.op",
    "patterns": [{ "include": "#comment" }, { "include": "#front-matter" }, { "include": "#security-decl" }, { "include": "#route-declaration" }],
    "repository": {
        "comment": {
            "match": "#.*$",
            "name": "comment.line.number-sign.op"
        },
        "front-matter": {
            "begin": "(---)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.front-matter.begin.op" }
            },
            "end": "(---)",
            "endCaptures": {
                "1": { "name": "punctuation.definition.front-matter.end.op" }
            },
            "patterns": [{ "include": "#comment" }, { "include": "#meta-entry" }]
        },
        "meta-entry": {
            "match": "([a-zA-Z_$][a-zA-Z0-9_$.-]*)\\s*(:)\\s*(?:(\"[^\"]*\"|'[^']*')|([a-zA-Z_$][a-zA-Z0-9_$.-]*))",
            "captures": {
                "1": { "name": "entity.other.attribute-name.op" },
                "2": { "name": "punctuation.separator.colon.op" },
                "3": { "name": "string.quoted.op" },
                "4": { "name": "string.unquoted.op" }
            }
        },
        "route-declaration": {
            "begin": "(/[a-zA-Z0-9_/:.-]+)(?:\\s*(:)\\s*((?:internal|deprecated)(?:\\s+(?:internal|deprecated))*))?\\s*(\\{)",
            "beginCaptures": {
                "1": {
                    "patterns": [{ "include": "#route-path" }]
                },
                "2": { "name": "punctuation.separator.colon.op" },
                "3": { "patterns": [{ "match": "\\b(internal|deprecated)\\b", "name": "keyword.control.modifier.op" }] },
                "4": { "name": "punctuation.definition.block.begin.op" }
            },
            "end": "(\\})",
            "endCaptures": {
                "1": { "name": "punctuation.definition.block.end.op" }
            },
            "patterns": [{ "include": "#comment" }, { "include": "#security-decl" }, { "include": "#params-block" }, { "include": "#http-operation" }]
        },
        "route-path": {
            "patterns": [
                {
                    "match": "(:)([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "keyword.operator.param-prefix.op" },
                        "2": { "name": "variable.parameter.path.op" }
                    }
                },
                {
                    "match": "/",
                    "name": "punctuation.separator.slash.op"
                },
                {
                    "match": "[a-zA-Z_][a-zA-Z0-9_.]*",
                    "name": "string.unquoted.path-segment.op"
                }
            ]
        },
        "params-block": {
            "begin": "\\b(?:(strict|strip|loose)\\s+)?(params)\\b",
            "beginCaptures": {
                "1": { "name": "keyword.control.object-mode.op" },
                "2": { "name": "keyword.control.params.op" }
            },
            "end": "(?<=\\})|(?=\\b(?:get|post|put|patch|delete|security)\\b)|(?=\\})",
            "patterns": [{ "include": "#comment" }, { "include": "#type-shorthand" }, { "include": "#param-decl-block" }]
        },
        "http-operation": {
            "begin": "\\b(get|post|put|patch|delete)\\b\\s*(?:(:)\\s*)?",
            "beginCaptures": {
                "1": { "name": "keyword.control.http-method.op" },
                "2": { "name": "punctuation.separator.colon.op" }
            },
            "end": "(?<=\\})|(?=\\b(?:get|post|put|patch|delete|params|security)\\b)|(?=\\})",
            "patterns": [{ "match": "\\b(internal|deprecated|public)\\b", "name": "keyword.control.modifier.op" }, { "include": "#operation-body" }]
        },
        "operation-body": {
            "begin": "(\\{)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.block.begin.op" }
            },
            "end": "(\\})",
            "endCaptures": {
                "1": { "name": "punctuation.definition.block.end.op" }
            },
            "patterns": [
                { "include": "#comment" },
                { "include": "#service-decl" },
                { "include": "#sdk-decl" },
                { "include": "#signature-decl" },
                { "include": "#security-decl" },
                { "include": "#query-block" },
                { "include": "#headers-block" },
                { "include": "#request-block" },
                { "include": "#response-block" }
            ]
        },
        "service-decl": {
            "match": "\\b(service)\\s*(:)\\s*([a-zA-Z_$][a-zA-Z0-9_$.]*)",
            "captures": {
                "1": { "name": "keyword.control.service.op" },
                "2": { "name": "punctuation.separator.colon.op" },
                "3": { "name": "entity.name.function.service-ref.op" }
            }
        },
        "sdk-decl": {
            "match": "\\b(sdk)\\s*(:)\\s*([a-zA-Z_$][a-zA-Z0-9_$]*)",
            "captures": {
                "1": { "name": "keyword.control.sdk.op" },
                "2": { "name": "punctuation.separator.colon.op" },
                "3": { "name": "entity.name.function.sdk-method.op" }
            }
        },
        "signature-decl": {
            "comment": "signature: KEY_NAME or signature: \"quoted-key\" — HMAC key name at operation level",
            "match": "\\b(signature)\\s*(:)\\s*(\"[^\"]*\"|[a-zA-Z_$][a-zA-Z0-9_$]*)",
            "captures": {
                "1": { "name": "keyword.control.signature.op" },
                "2": { "name": "punctuation.separator.colon.op" },
                "3": { "name": "string.unquoted.op" }
            }
        },
        "security-decl": {
            "patterns": [
                {
                    "comment": "security: none — inline public form",
                    "match": "\\b(security)\\s*(:)\\s*(none)\\b",
                    "captures": {
                        "1": { "name": "keyword.control.security.op" },
                        "2": { "name": "punctuation.separator.colon.op" },
                        "3": { "name": "keyword.control.security.none.op" }
                    }
                },
                {
                    "comment": "security: { ... } — block form with roles",
                    "begin": "\\b(security)\\s*(:)\\s*(\\{)",
                    "beginCaptures": {
                        "1": { "name": "keyword.control.security.op" },
                        "2": { "name": "punctuation.separator.colon.op" },
                        "3": { "name": "punctuation.definition.block.begin.op" }
                    },
                    "end": "(\\})",
                    "endCaptures": {
                        "1": { "name": "punctuation.definition.block.end.op" }
                    },
                    "patterns": [{ "include": "#comment" }, { "include": "#security-roles-line" }]
                }
            ]
        },
        "security-roles-line": {
            "comment": "roles: admin moderator — role name allowlist",
            "match": "\\b(roles)\\s*(:)\\s*([a-zA-Z_][a-zA-Z0-9_ ]*)",
            "captures": {
                "1": { "name": "keyword.control.security.roles.op" },
                "2": { "name": "punctuation.separator.colon.op" },
                "3": { "name": "string.unquoted.op" }
            }
        },
        "query-block": {
            "begin": "\\b(?:(strict|strip|loose)\\s+)?(query)\\b",
            "beginCaptures": {
                "1": { "name": "keyword.control.object-mode.op" },
                "2": { "name": "keyword.control.query.op" }
            },
            "end": "(?<=\\})|(?=\\b(?:service|sdk|signature|security|query|headers|request|response)\\b)|(?=\\})",
            "patterns": [{ "include": "#comment" }, { "include": "#type-shorthand" }, { "include": "#param-decl-block" }]
        },
        "headers-block": {
            "begin": "\\b(?:(strict|strip|loose)\\s+)?(headers)\\b",
            "beginCaptures": {
                "1": { "name": "keyword.control.object-mode.op" },
                "2": { "name": "keyword.control.headers.op" }
            },
            "end": "(?<=\\})|(?=\\b(?:service|sdk|signature|security|query|headers|request|response)\\b)|(?=\\})",
            "patterns": [{ "include": "#comment" }, { "include": "#type-shorthand" }, { "include": "#param-decl-block" }]
        },
        "request-block": {
            "begin": "\\b(request)\\s*(:)\\s*(\\{)",
            "beginCaptures": {
                "1": { "name": "keyword.control.request.op" },
                "2": { "name": "punctuation.separator.colon.op" },
                "3": { "name": "punctuation.definition.block.begin.op" }
            },
            "end": "(\\})",
            "endCaptures": {
                "1": { "name": "punctuation.definition.block.end.op" }
            },
            "patterns": [{ "include": "#comment" }, { "include": "#content-type-line" }]
        },
        "response-block": {
            "begin": "\\b(response)\\s*(:)\\s*(\\{)",
            "beginCaptures": {
                "1": { "name": "keyword.control.response.op" },
                "2": { "name": "punctuation.separator.colon.op" },
                "3": { "name": "punctuation.definition.block.begin.op" }
            },
            "end": "(\\})",
            "endCaptures": {
                "1": { "name": "punctuation.definition.block.end.op" }
            },
            "patterns": [{ "include": "#comment" }, { "include": "#status-code-block" }]
        },
        "status-code-block": {
            "begin": "\\b(\\d{3})\\b\\s*(:)\\s*",
            "beginCaptures": {
                "1": { "name": "keyword.control.status-code.op" },
                "2": { "name": "punctuation.separator.colon.op" }
            },
            "end": "(?<=\\})|(?=\\d{3})|(?=\\})",
            "patterns": [
                {
                    "begin": "(\\{)",
                    "beginCaptures": {
                        "1": { "name": "punctuation.definition.block.begin.op" }
                    },
                    "end": "(\\})",
                    "endCaptures": {
                        "1": { "name": "punctuation.definition.block.end.op" }
                    },
                    "patterns": [{ "include": "#comment" }, { "include": "#headers-block" }, { "include": "#content-type-line" }]
                }
            ]
        },
        "content-type-line": {
            "begin": "([a-zA-Z][a-zA-Z0-9-]*/[a-zA-Z][a-zA-Z0-9.+-]*)\\s*(:)\\s*",
            "beginCaptures": {
                "1": { "name": "entity.name.section.content-type.op" },
                "2": { "name": "punctuation.separator.colon.op" }
            },
            "end": "(?=\\s*$)|(?=\\s*#)|(?=\\})",
            "patterns": [{ "include": "#type-expression" }]
        },
        "type-shorthand": {
            "begin": "(:)\\s*",
            "beginCaptures": {
                "1": { "name": "punctuation.separator.colon.op" }
            },
            "end": "(?=\\s*\\{)|(?=\\s*$)|(?=\\s*#)|(?=\\})",
            "patterns": [{ "include": "#type-expression" }]
        },
        "param-decl-block": {
            "begin": "(\\{)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.block.begin.op" }
            },
            "end": "(\\})",
            "endCaptures": {
                "1": { "name": "punctuation.definition.block.end.op" }
            },
            "patterns": [{ "include": "#comment" }, { "include": "#param-declaration" }]
        },
        "param-declaration": {
            "begin": "([a-zA-Z_][a-zA-Z0-9_]*(?:-[a-zA-Z0-9_]+)*)(\\?)?\\s*(:)\\s*",
            "beginCaptures": {
                "1": { "name": "variable.other.param.op" },
                "2": { "name": "keyword.operator.optional.op" },
                "3": { "name": "punctuation.separator.colon.op" }
            },
            "end": "(?=$|#|\\}|[a-zA-Z_][a-zA-Z0-9_]*(?:-[a-zA-Z0-9_]+)*\\??\\s*:)",
            "patterns": [{ "include": "#type-expression" }]
        },
        "type-expression": {
            "patterns": [
                { "include": "#builtin-type" },
                { "include": "#compound-type" },
                { "include": "#type-constraints" },
                { "include": "#union-pipe" },
                { "include": "#intersection-ampersand" },
                { "include": "#postfix-array" },
                { "include": "#inline-object" },
                { "include": "#string-literal" },
                { "include": "#number-literal" },
                { "include": "#boolean-literal" },
                { "include": "#regex-literal" },
                { "include": "#model-reference" },
                { "include": "#enum-value" }
            ]
        },
        "builtin-type": {
            "match": "\\b(string|number|int|bigint|boolean|date|time|datetime|email|url|uuid|any|unknown|null|object|binary|json)\\b",
            "name": "support.type.builtin.op"
        },
        "compound-type": {
            "match": "\\b(array|tuple|record|enum|literal|lazy)\\b",
            "name": "support.type.compound.op"
        },
        "type-constraints": {
            "begin": "(\\()",
            "beginCaptures": {
                "1": { "name": "punctuation.parenthesis.open.op" }
            },
            "end": "(\\))",
            "endCaptures": {
                "1": { "name": "punctuation.parenthesis.close.op" }
            },
            "patterns": [
                { "include": "#constraint-key-value" },
                { "include": "#type-expression" },
                { "include": "#string-literal" },
                { "include": "#number-literal" },
                { "include": "#boolean-literal" },
                { "include": "#regex-literal" },
                { "include": "#comma" }
            ]
        },
        "constraint-key-value": {
            "match": "\\b(min|max|length|len|regex|format)\\s*(=)",
            "captures": {
                "1": { "name": "variable.parameter.constraint.op" },
                "2": { "name": "keyword.operator.assignment.op" }
            }
        },
        "model-reference": {
            "match": "\\b([A-Z][a-zA-Z0-9_$]*)\\b",
            "name": "entity.name.type.reference.op"
        },
        "enum-value": {
            "match": "\\b([a-z][a-zA-Z0-9_$.-]*)\\b",
            "name": "string.unquoted.op"
        },
        "union-pipe": {
            "match": "\\|",
            "name": "keyword.operator.union.op"
        },
        "intersection-ampersand": {
            "match": "&",
            "name": "keyword.operator.intersection.op"
        },
        "postfix-array": {
            "match": "\\[\\]",
            "name": "punctuation.definition.array.op"
        },
        "inline-object": {
            "begin": "(?:(strict|strip|loose)\\s+)?(\\{)",
            "beginCaptures": {
                "1": { "name": "keyword.control.object-mode.op" },
                "2": { "name": "punctuation.definition.block.begin.op" }
            },
            "end": "(\\})",
            "endCaptures": {
                "1": { "name": "punctuation.definition.block.end.op" }
            },
            "patterns": [{ "include": "#comment" }, { "include": "#param-declaration" }, { "include": "#comma" }]
        },
        "string-literal": {
            "patterns": [
                {
                    "begin": "\"",
                    "end": "\"",
                    "name": "string.quoted.double.op"
                },
                {
                    "begin": "'",
                    "end": "'",
                    "name": "string.quoted.single.op"
                }
            ]
        },
        "number-literal": {
            "match": "-?\\d+(\\.\\d+)?",
            "name": "constant.numeric.op"
        },
        "boolean-literal": {
            "match": "\\b(true|false)\\b",
            "name": "constant.language.boolean.op"
        },
        "regex-literal": {
            "match": "/[^/]+/",
            "name": "string.regexp.op"
        },
        "comma": {
            "match": ",",
            "name": "punctuation.separator.comma.op"
        }
    }
}
