{
    "name": "@contractkit/openapi-to-ck",
    "version": "0.7.1",
    "description": "Convert OpenAPI specs (2.0/3.0/3.1) to Contract Kit .ck files",
    "author": {
        "name": "Marooned Software",
        "url": "https://github.com/MaroonedSoftware/contractkit"
    },
    "bugs": {
        "url": "https://github.com/MaroonedSoftware/contractkit/issues"
    },
    "homepage": "https://github.com/MaroonedSoftware/contractkit/packages/openapi-to-ck#readme",
    "keywords": [
        "contractkit",
        "openapi"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/MaroonedSoftware/contractkit.git"
    },
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js",
        "./plugin": "./dist/plugin.js"
    },
    "scripts": {
        "build": "tsup src/index.ts src/plugin.ts --format esm --sourcemap --dts && tsc --emitDeclarationOnly --declaration",
        "build:ci": "eslint --max-warnings=0 && pnpm run build",
        "lint": "eslint --fix",
        "format": "prettier --write .",
        "test": "vitest run",
        "test:ci": "vitest run --coverage"
    },
    "dependencies": {
        "@contractkit/core": "workspace:*",
        "@scalar/openapi-parser": "^0.26.1",
        "yaml": "^2.8.3"
    },
    "devDependencies": {
        "@repo/config-eslint": "workspace:*",
        "@repo/config-typescript": "workspace:*"
    }
}
