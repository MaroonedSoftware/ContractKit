{
    "name": "@maroonedsoftware/openapi-to-ck",
    "version": "0.4.2",
    "description": "Convert OpenAPI specs (2.0/3.0/3.1) to Contract Kit .ck files",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js",
        "./plugin": "./dist/plugin.js"
    },
    "scripts": {
        "build": "tsup src/index.ts src/plugin.ts --format esm --sourcemap --dts && tsc --emitDeclarationOnly --declaration",
        "build:ci": "eslint --max-warnings=0 && pnpm run build",
        "lint": "eslint --fix",
        "format": "prettier --write .",
        "test": "vitest run",
        "test:ci": "vitest run --coverage"
    },
    "dependencies": {
        "@maroonedsoftware/contractkit": "workspace:*",
        "@scalar/openapi-parser": "^0.10.0",
        "yaml": "^2.7.0"
    },
    "devDependencies": {
        "@repo/config-eslint": "workspace:*",
        "@repo/config-typescript": "workspace:*"
    }
}
