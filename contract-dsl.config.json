{
    "rootDir": "~/projects/homegrown_v2/",
    "cache": true,
    "server": {
        "baseDir": "apps/api/",
        "types": {
            "output": "src/modules/{area}/types/{filename}.ts",
            "include": ["contracts/types/**/*.dto"]
        },
        "routes": {
            "output": "src/routes/{filename}.router.ts",
            "include": ["contracts/operations/**/*.op"],
            "servicePathTemplate": "#modules/{module}/{module}.service.js",
            "typeImportPathTemplate": "#modules/{module}/types/index.js"
        }
    },
    "sdk": {
        "baseDir": "packages/sdk/",
        "name": "homegrown",
        "output": "src/{name}.sdk.ts",
        "types": {
            "output": "src/{area}/types/{filename}.ts",
            "include": ["contracts/types/**/*.dto"]
        },
        "clients": {
            "output": "src/{area}/{filename}.client.ts",
            "include": ["contracts/operations/**/*.op"]
        }
    },
    "docs": {
        "markdown": {
            "baseDir": "docs/",
            "output": "api-reference.md"
        },
        "openapi": {
            "baseDir": "docs/api/",
            "output": "openapi.yaml",
            "info": {
                "title": "Homegrown API",
                "version": "1.0.0",
                "description": "Homegrown API"
            },
            "servers": [
                { "url": "https://api.joinhomegrown.com", "description": "Production" },
                { "url": "https://localhost:3000", "description": "Local" }
            ],
            "securitySchemes": {
                "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
            },
            "security": [{ "bearerAuth": [] }]
        }
    }
}
